# ============================================================
# CareerCompass environment configuration
# Copy this file to .env and fill in the provider you want.
# The app runs in DEMO mode with no keys at all.
# ============================================================

# Which LLM provider to use: gemini | nvidia | mistral | bedrock | demo
# Leave unset to auto-detect from the keys below (falls back to demo).
LLM_PROVIDER=

# ---- Google Gemini (free tier available) ----
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---- NVIDIA NIM (OpenAI-compatible, free tier) ----
# Get a key: https://build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_MODEL=minimaxai/minimax-m2.7
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ---- Mistral AI (direct API) ----
# Get a key: https://console.mistral.ai
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# ---- AWS Bedrock (great for AWS Activate credits) ----
# Uses the standard AWS credential chain (IAM role on EC2 recommended).
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
AWS_REGION=us-east-1

# ---- Authentication (Auth.js / Google sign-in) ----
# Required. Generate one with:  openssl rand -base64 33
AUTH_SECRET=
# Trust the proxy host when self-hosting (EC2, Docker, load balancer).
AUTH_TRUST_HOST=true
# Your public URL in production, e.g. https://your-domain.com
# (Safe to leave blank for local development.)
AUTH_URL=
# Google OAuth client: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI:  <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
